# Production environment — copy to .env.prod and fill in strong secrets

POSTGRES_USER=finance
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=finance_db

JWT_SECRET=change-me-long-random-jwt-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-admin-password
ADMIN_FULL_NAME=Administrator
MONTHLY_PLAN=50000000

WEB_PORT=80

# HTTPS (Caddy reverse proxy) — haqiqiy domenda ishlatish uchun:
# 1. DOMAIN — Finance panel (masalan wtma.okaposai.uz)
# 2. LANDING_DOMAIN — Marketing landing (masalan landing.okaposai.uz)
# 3. DNS'da ikkala domenning A yozuvi server IP manziliga yo'naltirilgan bo'lsin
# 4. ACME_EMAIL — Let's Encrypt bildirishnomalari uchun
DOMAIN=wtma.okaposai.uz
LANDING_DOMAIN=landing.okaposai.uz
ACME_EMAIL=internal@example.com
HTTP_PORT=80
HTTPS_PORT=443
