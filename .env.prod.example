# Production environment — copy to .env.prod and fill in strong secrets

POSTGRES_USER=finance
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=finance_db

JWT_SECRET=change-me-long-random-jwt-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-admin-password
ADMIN_FULL_NAME=Administrator
MONTHLY_PLAN=50000000

WEB_PORT=80

# HTTPS (Caddy reverse proxy) — haqiqiy domenda ishlatish uchun:
# 1. DOMAIN'ni o'zingizning domeningizga almashtiring (masalan finance.example.com)
# 2. DNS'da shu domenning A yozuvi ushbu server IP manziliga yo'naltirilgan bo'lsin
# 3. ACME_EMAIL — Let's Encrypt bildirishnomalari uchun (sertifikat muddati va h.k.)
# Lokal sinov uchun DOMAIN=localhost qoldiring — Caddy o'z-o'zidan imzolangan
# (self-signed) sertifikat bilan ishlaydi (brauzer ogohlantiradi, bu normal).
DOMAIN=localhost
ACME_EMAIL=internal@example.com
HTTP_PORT=80
HTTPS_PORT=443
